#Function that catch user input, calculates user BMI, save and displays the status.

def bmi():
    global message
    global weight
    global height
    weight = float(input("Your weight (kg): "))
    height = float(input("Your height(m): "))
    formula_bmi = weight / (height**2)

    tracks = [
        (18.5, "Underweight"),
        (25.0, "Healthy weight"),
        (30.0, "Overweight"),
        (35.0, "Obesity class I"),
        (40.0, "Obesity class II")]

    for limit, message in tracks:
        if formula_bmi < limit:
            return f"{message}"
        
    return "Obesity class III"

#Start program

print(bmi())

#Create file with data of user

with open("bmi.txt","w",encoding="utf-8") as file:
    file.write(f"Weight of user: {weight}\n"
               f"Height of user: {height}\n"
                f"BMI of user: {message}")